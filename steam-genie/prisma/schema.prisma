// Steam Genie — Prisma Schema
// Architecture v1.2 — June 2026

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Platform {
  IOS
  ANDROID
}

enum TaskFrequency {
  EVENTUAL  // Only used in work orders — NEVER in the periodic tasks module
  DAILY
  MON_FRI
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  BIANNUAL
  ANNUAL
}

enum TaskFieldType {
  DROPDOWN
}

enum ReservationStatus {
  UPCOMING
  CHECKIN_DAY
  ACTIVE
  CHECKOUT_DAY
  COMPLETED
}

enum ReservationSource {
  API
  MANUAL
}

enum WorkOrderType {
  CHECKOUT_CLEANING // Auto-generated from a reservation
  ADDITIONAL_REQUEST // Manual request; cleaners can self-assign
}

enum WorkOrderStatus {
  UNASSIGNED
  /// Servicio creado desde presupuesto (cliente eventual); aguarda checklist + asignación.
  QUOTE_ACCEPTED
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum AssignmentStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum RejectionReasonType {
  SERVICE_REJECTION // Applied to work_order_assignments
  TASK_NOT_DONE     // Applied to task_executions
}

enum ServiceExecutionStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskExecutionStatus {
  DONE
  NOT_DONE
  SKIPPED
}

enum PeriodicTaskInstanceStatus {
  PENDING
  COMPLETED
  EXPIRED
}

/// High-level building operation mode. SIMPLE groups simpler workflows
/// (phase photo evidence, etc.). DETAILED keeps the richer per-task flows.
enum BuildingMode {
  SIMPLE
  DETAILED
}

enum PhotoEvidenceMode {
  PER_TASK
  BEFORE_DURING_AFTER
}

enum PhotoPhase {
  BEFORE
  DURING
  AFTER
}

enum QuoteStatus {
  COTIZADO
  EN_ESPERA
  ACEPTADO
  RECHAZADO
  TERMINADO
}

enum IntegrationLogStatus {
  RECEIVED
  PARSED
  ERROR
}

enum SyncConflictResolutionStatus {
  PENDING
  RESOLVED
}

enum StockUnitType {
  UNIT
  LITER
  KILOGRAM
  GRAM
  MILLILITER
  PACK
  BOX
  BOTTLE
  ROLL
  OTHER
}

enum StockShipmentOrderStatus {
  DRAFT
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum StockShipmentDestinationStatus {
  PENDING
  DELIVERED
  CANCELLED
}

enum StockShipmentLineStatus {
  PENDING
  DELIVERED
  CANCELLED
}

enum BuildingStockAlertType {
  LOW_STOCK
  OUT_OF_STOCK
  OBSERVATION
}

enum BuildingStockAlertStatus {
  OPEN
  IN_TRANSIT
  RESOLVED
}

enum StockMovementScope {
  DEPOT
  BUILDING
}

enum StockMovementType {
  DEPOT_INITIAL
  DEPOT_ADJUST
  DEPOT_SET
  DEPOT_RESERVE
  DEPOT_RESERVE_RELEASE
  DEPOT_SHIP_OUT
  BUILDING_SET
  BUILDING_RECEIVE
}

// ─── Users & Access ───────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  dni          String   @unique @db.VarChar(20)
  fullName     String   @db.VarChar(200)
  birthDate    DateTime? @db.Date
  passwordHash String   @db.VarChar(255)
  // Denormalized for fast auth queries only.
  // Source of truth for permissions is UserBuildingRole.
  primaryRole  String   @db.VarChar(50)
  isActive     Boolean  @default(true)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  buildingRoles     UserBuildingRole[] @relation("UserBuildingRoles")
  grantedRoles      UserBuildingRole[] @relation("GrantedByUser")
  devices           UserDevice[]
  attendances       Attendance[]
  assignments       WorkOrderAssignment[]
  createdWorkOrders WorkOrder[]
  serviceExecutions               ServiceExecution[]
  serviceExecutionParticipants    ServiceExecutionParticipant[]
  taskExecutions                  TaskExecutionRecord[]
  uploadedPhotos                  TaskPhoto[]
  uploadedServiceExecutionPhotos  ServiceExecutionPhoto[]
  uploadedPeriodicInstancePhotos  PeriodicTaskInstancePhoto[]
  correctedAttendances            Attendance[]  @relation("CorrectedBy")
  resolvedConflicts SyncConflict[]  @relation("SyncConflictResolvedBy")
  ownedConflicts    SyncConflict[]  @relation("SyncConflictUser")
  syncOperations    SyncOperation[]
  auditLogs         AuditLog[]
  domainEvents      DomainEvent[]
  buildingStockAlerts      BuildingStockAlert[]       @relation("BuildingStockAlertReporter")
  confirmedStockDeliveries   StockShipmentDestination[] @relation("StockDeliveryConfirmer")
  createdStockShipmentOrders StockShipmentOrder[]     @relation("StockShipmentCreator")
  dispatchedStockOrders      StockShipmentOrder[]     @relation("StockShipmentDispatcher")
  stockMovements             StockMovement[]          @relation("StockMovementPerformer")
  workOrderExpenses          WorkOrderExpense[]       @relation("WorkOrderExpenseCreator")
  fixedExpensesCreated       FixedExpense[]           @relation("FixedExpenseCreator")
  commissionSettlements      CommissionSettlement[]   @relation("CommissionBeneficiary")
  commissionsCreated         CommissionSettlement[]   @relation("CommissionCreator")
  commissionPdfVersions      CommissionSettlementPdfVersion[] @relation("CommissionPdfCreator")
  createdQuotes              Quote[]                          @relation("QuoteCreator")

  @@index([deletedAt, fullName])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(50) // admin | manager | cleaner | client | provider
  description String?  @db.VarChar(200)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userBuildingRoles UserBuildingRole[]
  permissions       RolePermission[]

  @@map("roles")
}

model RolePermission {
  id        String @id @default(uuid()) @db.Uuid
  role      Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId    String @db.Uuid
  moduleKey String @db.VarChar(50)

  @@unique([roleId, moduleKey])
  @@map("role_permissions")
}

// Roles scoped per building (building_id = null means global role)
model UserBuildingRole {
  id         String   @id @default(uuid()) @db.Uuid
  user       User     @relation("UserBuildingRoles", fields: [userId], references: [id])
  userId     String   @db.Uuid
  building   Building? @relation(fields: [buildingId], references: [id])
  buildingId String?  @db.Uuid // null = global role across all buildings
  role       Role     @relation(fields: [roleId], references: [id])
  roleId     String   @db.Uuid
  grantedBy  User     @relation("GrantedByUser", fields: [grantedById], references: [id])
  grantedById String  @db.Uuid
  createdAt  DateTime @default(now())

  @@index([userId, buildingId, roleId])
  @@map("user_building_roles")
}

model UserDevice {
  id          String   @id @default(uuid()) @db.Uuid
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @db.Uuid
  deviceId    String   @unique @db.VarChar(200)
  platform    Platform
  pushToken   String?  @db.VarChar(500) // Updated on every app start
  appVersion  String?  @db.VarChar(50)
  lastSeenAt  DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("user_devices")
}

// ─── Buildings ────────────────────────────────────────────────────────────────

model Building {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  address     String?  @db.VarChar(300)
  city        String?  @db.VarChar(100)
  province    String?  @db.VarChar(100)
  latitude             Decimal? @db.Decimal(10, 7)
  longitude            Decimal? @db.Decimal(10, 7)
  gpsRadiusM           Int      @default(200)
  /// If true, check-in/out must be within the building GPS radius.
  requireGpsValidation Boolean  @default(true)
  /// SIMPLE = simpler workflows (phase photos, etc.). DETAILED = richer per-task flows.
  buildingMode         BuildingMode      @default(DETAILED)
  /// Only meaningful when buildingMode = SIMPLE.
  /// PER_TASK = photo per checklist task (default). BEFORE_DURING_AFTER = phase photos on the service/instance.
  photoEvidenceMode    PhotoEvidenceMode @default(PER_TASK)
  isActive             Boolean  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  floors            Floor[]
  zones             Zone[]
  subzones          Subzone[]
  tasks             Task[]
  userBuildingRoles UserBuildingRole[]
  attendances       Attendance[]
  workOrders        WorkOrder[]
  reservations      Reservation[]
  buildingStockItems        BuildingStockItem[]
  buildingStockAlerts       BuildingStockAlert[]
  stockShipmentDestinations StockShipmentDestination[]
  stockMovements            StockMovement[]
  fixedExpenses             FixedExpense[]
  quotes                    Quote[]
  /// Si existe, este "edificio" es el sitio operativo de un cliente particular.
  particularClient  ParticularClient?

  @@index([deletedAt])
  @@map("buildings")
}

/// Cliente particular o empresa suelta. Tiene un Building vinculado para GPS/zonas/subzonas/WOs.
model ParticularClient {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(200)
  taxId       String?   @db.VarChar(20)
  address     String?   @db.VarChar(300)
  contactName String?   @db.VarChar(200)
  email       String?   @db.VarChar(200)
  phone       String?   @db.VarChar(50)
  notes       String?   @db.VarChar(1000)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  building    Building  @relation(fields: [buildingId], references: [id])
  buildingId  String    @unique @db.Uuid
  quotes      Quote[]

  @@index([deletedAt])
  @@index([name])
  @@map("particular_clients")
}

/// Cliente eventual: solo nombre y dirección (sin sitio operativo).
model EventualClient {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(200)
  address   String?   @db.VarChar(300)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  quotes Quote[]

  @@index([deletedAt])
  @@index([name])
  @@map("eventual_clients")
}

// ─── Presupuestos ─────────────────────────────────────────────────────────────

/// Contador correlativo de presupuestos (una sola fila).
model QuoteCounter {
  id         String @id @default("default") @db.VarChar(20)
  nextNumber Int    @default(1)

  @@map("quote_counters")
}

model Quote {
  id     String      @id @default(uuid()) @db.Uuid
  number Int         @unique
  status QuoteStatus @default(COTIZADO)

  /// Cliente: particular XOR edificio XOR cliente eventual (uno obligatorio).
  particularClient   ParticularClient? @relation(fields: [particularClientId], references: [id])
  particularClientId String?           @db.Uuid
  building           Building?         @relation(fields: [buildingId], references: [id])
  buildingId         String?           @db.Uuid
  eventualClient     EventualClient?   @relation(fields: [eventualClientId], references: [id])
  eventualClientId   String?           @db.Uuid

  requestDate        DateTime  @db.Date
  serviceType        String?   @db.VarChar(500)
  clientDetails      String?   @db.VarChar(2000)
  /// Contacto para envío (WhatsApp / correo). Se precarga del cliente particular.
  contactPhone       String?   @db.VarChar(50)
  contactEmail       String?   @db.VarChar(200)
  sellerName         String?   @db.VarChar(200)
  paymentCondition   String?   @db.VarChar(100)
  paymentTerms       String?   @db.VarChar(500)
  observations       String?   @db.VarChar(1000)
  validUntil         DateTime? @db.Date

  subtotal         Decimal  @db.Decimal(14, 2)
  discountPercent  Decimal? @db.Decimal(5, 2)
  vatRate          Decimal  @default(21) @db.Decimal(5, 2)
  vatAmount        Decimal  @db.Decimal(14, 2)
  total            Decimal  @db.Decimal(14, 2)

  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id])
  workOrderId String?    @unique @db.Uuid

  createdBy   User   @relation("QuoteCreator", fields: [createdById], references: [id])
  createdById String @db.Uuid

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  items QuoteItem[]

  @@index([status, requestDate])
  @@index([particularClientId])
  @@index([buildingId])
  @@index([eventualClientId])
  @@index([deletedAt, requestDate])
  @@map("quotes")
}

model QuoteItem {
  id              String   @id @default(uuid()) @db.Uuid
  quote           Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId         String   @db.Uuid
  quantity        Decimal  @db.Decimal(12, 3)
  description     String   @db.VarChar(1000)
  unitPrice       Decimal  @db.Decimal(14, 2)
  discountPercent Decimal? @db.Decimal(5, 2)
  lineTotal       Decimal  @db.Decimal(14, 2)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([quoteId, sortOrder])
  @@map("quote_items")
}

model Floor {
  id         String   @id @default(uuid()) @db.Uuid
  building   Building @relation(fields: [buildingId], references: [id])
  buildingId String   @db.Uuid
  name       String   @db.VarChar(100)
  sortOrder  Int      @default(0)
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  zones        Zone[]
  workOrders   WorkOrder[]
  reservations Reservation[]

  @@index([buildingId, deletedAt])
  @@map("floors")
}

model Zone {
  id          String   @id @default(uuid()) @db.Uuid
  floor       Floor    @relation(fields: [floorId], references: [id])
  floorId     String   @db.Uuid
  building    Building @relation(fields: [buildingId], references: [id])
  buildingId  String   @db.Uuid // Denormalized for queries
  name        String   @db.VarChar(200)
  qrToken     String?  @unique @db.VarChar(100)
  qrExpiresAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subzones     Subzone[]
  tasks        Task[]
  workOrders   WorkOrder[]
  reservations Reservation[]

  @@index([floorId, deletedAt])
  @@index([buildingId, deletedAt])
  @@map("zones")
}

model Subzone {
  id          String   @id @default(uuid()) @db.Uuid
  zone        Zone     @relation(fields: [zoneId], references: [id])
  zoneId      String   @db.Uuid
  building    Building @relation(fields: [buildingId], references: [id])
  buildingId  String   @db.Uuid // Denormalized for queries
  name        String   @db.VarChar(200)
  qrToken     String?  @unique @db.VarChar(100)
  qrExpiresAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks        Task[]
  workOrders   WorkOrder[]
  reservations Reservation[]

  @@index([zoneId, deletedAt])
  @@map("subzones")
}

// ─── Tasks ────────────────────────────────────────────────────────────────────

model TaskCategory {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(100)
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tasks Task[]

  @@index([deletedAt, sortOrder])
  @@map("task_categories")
}

model Task {
  id         String        @id @default(uuid()) @db.Uuid
  building   Building      @relation(fields: [buildingId], references: [id])
  buildingId String        @db.Uuid
  zone       Zone?         @relation(fields: [zoneId], references: [id])
  zoneId     String?       @db.Uuid
  subzone    Subzone?      @relation(fields: [subzoneId], references: [id])
  subzoneId  String?       @db.Uuid
  category   TaskCategory? @relation(fields: [categoryId], references: [id])
  categoryId String?       @db.Uuid
  name       String        @db.VarChar(300)
  frequency  TaskFrequency
  startDate  DateTime      @db.Date
  requiresPhoto           Boolean @default(false)
  allowsObservation       Boolean @default(false)
  requiresRejectionReason Boolean @default(false)
  isActive   Boolean       @default(true)
  deletedAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  customFields             TaskCustomField[]
  workOrderTaskSnapshots   WorkOrderTask[]
  periodicTaskInstances    PeriodicTaskInstance[]

  @@index([buildingId, zoneId, subzoneId, frequency])
  @@index([buildingId, isActive, deletedAt])
  @@index([categoryId, deletedAt])
  @@map("tasks")
}

model TaskCustomField {
  id           String        @id @default(uuid()) @db.Uuid
  task         Task          @relation(fields: [taskId], references: [id])
  taskId       String        @db.Uuid
  label        String        @db.VarChar(200)
  fieldType    TaskFieldType
  isRequired   Boolean       @default(false)
  showInReport Boolean       @default(false)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  options                      TaskCustomFieldOption[]
  workOrderTaskFieldSnapshots  WorkOrderTaskCustomField[]
  taskExecutionFieldValues     TaskExecutionFieldValue[]

  @@map("task_custom_fields")
}

model TaskCustomFieldOption {
  id        String          @id @default(uuid()) @db.Uuid
  field     TaskCustomField @relation(fields: [fieldId], references: [id])
  fieldId   String          @db.Uuid
  label     String          @db.VarChar(200)
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())

  workOrderTaskFieldOptionSnapshots WorkOrderTaskCustomFieldOption[]

  @@map("task_custom_field_options")
}

// ─── Stock ────────────────────────────────────────────────────────────────────

model StockCategory {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(100)
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products StockProduct[]

  @@index([deletedAt, sortOrder])
  @@map("stock_categories")
}

model StockSupplier {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    @db.VarChar(200)
  contactEmail String?   @db.VarChar(200)
  contactPhone String?   @db.VarChar(50)
  isActive     Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  products StockProduct[]

  @@index([deletedAt])
  @@map("stock_suppliers")
}

model StockProduct {
  id               String         @id @default(uuid()) @db.Uuid
  name             String         @db.VarChar(300)
  sku              String?        @db.VarChar(100)
  description      String?        @db.VarChar(500)
  category         StockCategory  @relation(fields: [categoryId], references: [id])
  categoryId       String         @db.Uuid
  supplier         StockSupplier? @relation(fields: [supplierId], references: [id])
  supplierId       String?        @db.Uuid
  quantity         Decimal        @default(0) @db.Decimal(12, 3)
  reservedQuantity Decimal        @default(0) @db.Decimal(12, 3)
  minQuantity      Decimal        @default(5) @db.Decimal(12, 3)
  unitType         StockUnitType  @default(UNIT)
  isActive         Boolean        @default(true)
  deletedAt        DateTime?
  stockUpdatedAt   DateTime       @default(now())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  buildingStockItems BuildingStockItem[]
  buildingStockAlerts BuildingStockAlert[]
  shipmentLines      StockShipmentLine[]
  stockMovements     StockMovement[]

  @@index([categoryId, deletedAt])
  @@index([supplierId])
  @@map("stock_products")
}

// Stock asignado por edificio (subconjunto habilitado automáticamente o manualmente).
model BuildingStockItem {
  id         String       @id @default(uuid()) @db.Uuid
  building   Building     @relation(fields: [buildingId], references: [id])
  buildingId String       @db.Uuid
  product    StockProduct @relation(fields: [productId], references: [id])
  productId  String       @db.Uuid
  quantity   Decimal      @default(0) @db.Decimal(12, 3)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([buildingId, productId])
  @@index([buildingId])
  @@map("building_stock_items")
}

// Alertas reportadas por limpiadores fichados (no por umbral en edificio).
model BuildingStockAlert {
  id            String                   @id @default(uuid()) @db.Uuid
  building      Building                 @relation(fields: [buildingId], references: [id])
  buildingId    String                   @db.Uuid
  product       StockProduct             @relation(fields: [productId], references: [id])
  productId     String                   @db.Uuid
  reportedBy    User                     @relation("BuildingStockAlertReporter", fields: [reportedById], references: [id])
  reportedById  String                   @db.Uuid
  attendance    Attendance               @relation(fields: [attendanceId], references: [id])
  attendanceId  String                   @db.Uuid
  alertType     BuildingStockAlertType
  note          String?
  photoStorageKey    String?             @db.VarChar(500)
  photoStorageBucket String?             @db.VarChar(100) @default("local")
  status        BuildingStockAlertStatus @default(OPEN)
  shipmentDestination   StockShipmentDestination? @relation(fields: [shipmentDestinationId], references: [id])
  shipmentDestinationId String?                   @db.Uuid
  deliveryDate  DateTime?                @db.Date
  resolvedAt    DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@index([buildingId, status])
  @@index([productId, buildingId, status])
  @@map("building_stock_alerts")
}

model StockShipmentOrder {
  id            String                   @id @default(uuid()) @db.Uuid
  reference     String                   @unique @db.VarChar(50)
  status        StockShipmentOrderStatus @default(DRAFT)
  notes         String?
  createdBy     User                     @relation("StockShipmentCreator", fields: [createdById], references: [id])
  createdById   String                   @db.Uuid
  dispatchedBy  User?                    @relation("StockShipmentDispatcher", fields: [dispatchedById], references: [id])
  dispatchedById String?                 @db.Uuid
  dispatchedAt  DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  destinations StockShipmentDestination[]
  movements    StockMovement[]

  @@index([status, createdAt])
  @@map("stock_shipment_orders")
}

model StockShipmentDestination {
  id            String                         @id @default(uuid()) @db.Uuid
  order         StockShipmentOrder             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       String                         @db.Uuid
  building      Building                       @relation(fields: [buildingId], references: [id])
  buildingId    String                         @db.Uuid
  deliveryDate  DateTime?                      @db.Date
  status        StockShipmentDestinationStatus @default(PENDING)
  deliveredAt   DateTime?
  confirmedBy   User?                          @relation("StockDeliveryConfirmer", fields: [confirmedById], references: [id])
  confirmedById String?                        @db.Uuid
  createdAt     DateTime                       @default(now())
  updatedAt     DateTime                       @updatedAt

  lines  StockShipmentLine[]
  alerts BuildingStockAlert[]
  movements StockMovement[]

  @@unique([orderId, buildingId])
  @@index([buildingId, status])
  @@map("stock_shipment_destinations")
}

model StockShipmentLine {
  id            String                  @id @default(uuid()) @db.Uuid
  destination   StockShipmentDestination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  destinationId String                  @db.Uuid
  product       StockProduct            @relation(fields: [productId], references: [id])
  productId     String                  @db.Uuid
  quantity      Decimal                 @db.Decimal(12, 3)
  status        StockShipmentLineStatus @default(PENDING)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  movements StockMovement[]

  @@index([destinationId])
  @@map("stock_shipment_lines")
}

model StockMovement {
  id                    String             @id @default(uuid()) @db.Uuid
  scope                 StockMovementScope
  movementType          StockMovementType
  product               StockProduct       @relation(fields: [productId], references: [id])
  productId             String             @db.Uuid
  building              Building?          @relation(fields: [buildingId], references: [id])
  buildingId            String?            @db.Uuid
  quantityBefore        Decimal            @db.Decimal(12, 3)
  quantityDelta         Decimal            @db.Decimal(12, 3)
  quantityAfter         Decimal            @db.Decimal(12, 3)
  reservedBefore        Decimal?           @db.Decimal(12, 3)
  reservedDelta         Decimal?           @db.Decimal(12, 3)
  reservedAfter         Decimal?           @db.Decimal(12, 3)
  shipmentOrder         StockShipmentOrder? @relation(fields: [shipmentOrderId], references: [id])
  shipmentOrderId       String?            @db.Uuid
  shipmentDestination   StockShipmentDestination? @relation(fields: [shipmentDestinationId], references: [id])
  shipmentDestinationId String?            @db.Uuid
  shipmentLine          StockShipmentLine? @relation(fields: [shipmentLineId], references: [id])
  shipmentLineId        String?            @db.Uuid
  note                  String?
  performedBy           User?              @relation("StockMovementPerformer", fields: [performedById], references: [id])
  performedById         String?            @db.Uuid
  occurredAt            DateTime           @default(now())

  @@index([productId, occurredAt])
  @@index([buildingId, productId, occurredAt])
  @@index([shipmentOrderId])
  @@map("stock_movements")
}

// ─── Rejection Reasons ────────────────────────────────────────────────────────

model RejectionReason {
  id        String              @id @default(uuid()) @db.Uuid
  type      RejectionReasonType
  // SERVICE_REJECTION → used in WorkOrderAssignment
  // TASK_NOT_DONE     → used in TaskExecutionRecord
  text      String              @db.VarChar(300)
  isActive  Boolean             @default(true)
  deletedAt DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  assignments    WorkOrderAssignment[]
  taskExecutions TaskExecutionRecord[]

  @@map("rejection_reasons")
}

// ─── Attendance ───────────────────────────────────────────────────────────────

model Attendance {
  id                   String   @id @default(uuid()) @db.Uuid
  user                 User     @relation(fields: [userId], references: [id])
  userId               String   @db.Uuid
  building             Building @relation(fields: [buildingId], references: [id])
  buildingId           String   @db.Uuid
  checkInAt            DateTime
  checkInOccurredAt    DateTime?
  checkInGpsLat        Decimal? @db.Decimal(10, 7)
  checkInGpsLng        Decimal? @db.Decimal(10, 7)
  checkInDeviceId      String?  @db.VarChar(200)
  checkInIp            String?  @db.VarChar(45)
  /// Entrada fuera del radio GPS del edificio (advertencia; no bloquea).
  checkInOutOfRange    Boolean  @default(false)
  checkInDistanceM     Int?
  checkOutAt           DateTime?
  checkOutOccurredAt   DateTime?
  checkOutGpsLat       Decimal? @db.Decimal(10, 7)
  checkOutGpsLng       Decimal? @db.Decimal(10, 7)
  checkOutDeviceId     String?  @db.VarChar(200)
  checkOutIp           String?  @db.VarChar(45)
  /// Salida fuera del radio GPS del edificio (advertencia; no bloquea).
  checkOutOutOfRange   Boolean  @default(false)
  checkOutDistanceM    Int?
  forgotCheckout       Boolean  @default(false)
  isOfflineSynced      Boolean  @default(false)
  clientOperationId    String?  @unique @db.VarChar(100)
  correctedBy          User?    @relation("CorrectedBy", fields: [correctedById], references: [id])
  correctedById        String?  @db.Uuid
  correctionNote       String?
  version              Int      @default(1)
  deletedAt            DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  serviceExecutions                ServiceExecution[]
  serviceExecutionParticipants     ServiceExecutionParticipant[]
  buildingStockAlerts              BuildingStockAlert[]

  @@index([userId, buildingId, checkInAt])
  @@index([deletedAt, checkInAt])
  @@index([buildingId, checkInAt])
  @@index([userId, checkInAt])
  @@map("attendances")
}

// ─── Reservations ─────────────────────────────────────────────────────────────

model Reservation {
  id         String            @id @default(uuid()) @db.Uuid
  building   Building          @relation(fields: [buildingId], references: [id])
  buildingId String            @db.Uuid
  floor      Floor             @relation(fields: [floorId], references: [id])
  floorId    String            @db.Uuid
  zone       Zone              @relation(fields: [zoneId], references: [id])
  zoneId     String            @db.Uuid
  subzone    Subzone?          @relation(fields: [subzoneId], references: [id])
  subzoneId  String?           @db.Uuid
  externalId String?           @db.VarChar(200)
  guestName  String?           @db.VarChar(200)
  checkinAt  DateTime
  checkoutAt DateTime
  status     ReservationStatus @default(UPCOMING)
  source     ReservationSource @default(MANUAL)
  rawSource  String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  workOrders              WorkOrder[]
  integrationInboundLogs  IntegrationInboundLog[]

  @@index([buildingId, checkoutAt])
  @@index([checkoutAt])
  @@index([buildingId, checkinAt])
  @@index([buildingId, floorId, zoneId])
  @@index([zoneId, checkoutAt])
  @@map("reservations")
}

// ─── Work Orders ──────────────────────────────────────────────────────────────

model WorkOrder {
  id            String          @id @default(uuid()) @db.Uuid
  type          WorkOrderType
  reservation   Reservation?    @relation(fields: [reservationId], references: [id])
  reservationId String?         @db.Uuid // Required for CHECKOUT_CLEANING
  building      Building        @relation(fields: [buildingId], references: [id])
  buildingId    String          @db.Uuid
  floor         Floor?          @relation(fields: [floorId], references: [id])
  floorId       String?         @db.Uuid
  zone          Zone?           @relation(fields: [zoneId], references: [id])
  zoneId        String?         @db.Uuid
  subzone       Subzone?        @relation(fields: [subzoneId], references: [id])
  subzoneId     String?         @db.Uuid
  title         String          @db.VarChar(300)
  description   String?
  scheduledDate DateTime?       @db.Date
  scheduledTime DateTime?       @db.Time
  deadlineAt    DateTime?
  status        WorkOrderStatus @default(UNASSIGNED)
  /// Monto cobrado al cliente por este servicio eventual (opcional).
  clientAmountCharged Decimal?  @db.Decimal(12, 2)
  createdBy     User            @relation(fields: [createdById], references: [id])
  createdById   String          @db.Uuid
  startedAt     DateTime?
  completedAt   DateTime?
  version       Int             @default(1)
  deletedAt     DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  assignments        WorkOrderAssignment[]
  workOrderTasks     WorkOrderTask[]
  serviceExecutions  ServiceExecution[]
  integrationLogs    IntegrationInboundLog[]
  expenses           WorkOrderExpense[]
  commissionItems    CommissionSettlementItem[]
  quote              Quote?

  @@index([buildingId, status, scheduledDate])
  @@index([type, buildingId, status, scheduledDate])
  @@index([reservationId])
  @@index([zoneId, type, status, completedAt])
  @@map("work_orders")
}

model WorkOrderAssignment {
  id               String           @id @default(uuid()) @db.Uuid
  workOrder        WorkOrder        @relation(fields: [workOrderId], references: [id])
  workOrderId      String           @db.Uuid
  user             User             @relation(fields: [userId], references: [id])
  userId           String           @db.Uuid
  status           AssignmentStatus @default(PENDING)
  rejectionReason  RejectionReason? @relation(fields: [rejectionReasonId], references: [id])
  rejectionReasonId String?         @db.Uuid // Must be type SERVICE_REJECTION
  rejectionNote    String?
  respondedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([workOrderId, userId])
  @@index([userId, status])
  @@map("work_order_assignments")
}

// ─── Work Order Task Snapshots ────────────────────────────────────────────────
// Created when a WorkOrder is created. Snapshots EVENTUAL tasks at that moment.
// task_executions point here, NOT to the master tasks table.

model WorkOrderTask {
  id                               String    @id @default(uuid()) @db.Uuid
  workOrder                        WorkOrder @relation(fields: [workOrderId], references: [id])
  workOrderId                      String    @db.Uuid
  /// Null for custom checklist tasks (e.g. quote-sourced services without master EVENTUAL tasks).
  task                             Task?     @relation(fields: [taskId], references: [id])
  taskId                           String?   @db.Uuid
  nameSnapshot                     String    @db.VarChar(300)
  requiresPhotoSnapshot            Boolean
  allowsObservationSnapshot        Boolean
  requiresRejectionReasonSnapshot  Boolean
  sortOrder                        Int       @default(0)
  createdAt                        DateTime  @default(now())

  customFieldSnapshots WorkOrderTaskCustomField[]
  taskExecutions       TaskExecutionRecord[]

  @@index([workOrderId])
  @@map("work_order_tasks")
}

model WorkOrderTaskCustomField {
  id                String        @id @default(uuid()) @db.Uuid
  workOrderTask     WorkOrderTask @relation(fields: [workOrderTaskId], references: [id])
  workOrderTaskId   String        @db.Uuid
  originalField     TaskCustomField @relation(fields: [originalFieldId], references: [id])
  originalFieldId   String        @db.Uuid
  labelSnapshot     String        @db.VarChar(200)
  fieldType         String        @db.VarChar(50)
  isRequired        Boolean
  showInReport      Boolean
  sortOrder         Int           @default(0)
  createdAt         DateTime      @default(now())

  optionSnapshots        WorkOrderTaskCustomFieldOption[]
  taskExecutionFieldValues TaskExecutionFieldValue[]

  @@map("work_order_task_custom_fields")
}

model WorkOrderTaskCustomFieldOption {
  id                     String                   @id @default(uuid()) @db.Uuid
  workOrderTaskField     WorkOrderTaskCustomField @relation(fields: [workOrderTaskFieldId], references: [id])
  workOrderTaskFieldId   String                   @db.Uuid
  originalOption         TaskCustomFieldOption    @relation(fields: [originalOptionId], references: [id])
  originalOptionId       String                   @db.Uuid
  labelSnapshot          String                   @db.VarChar(200)
  sortOrder              Int                      @default(0)
  createdAt              DateTime                 @default(now())

  @@map("work_order_task_custom_field_options")
}

// ─── Service Executions ───────────────────────────────────────────────────────

model ServiceExecution {
  id                String                 @id @default(uuid()) @db.Uuid
  workOrder         WorkOrder              @relation(fields: [workOrderId], references: [id])
  workOrderId       String                 @db.Uuid
  attendance        Attendance             @relation(fields: [attendanceId], references: [id])
  attendanceId      String                 @db.Uuid
  startedBy         User                   @relation(fields: [startedById], references: [id])
  startedById       String                 @db.Uuid
  startedAt         DateTime
  occurredAt        DateTime? // Device timestamp (offline)
  completedAt       DateTime?
  status            ServiceExecutionStatus @default(IN_PROGRESS)
  clientOperationId String?                @unique @db.VarChar(100)
  isOfflineSynced   Boolean                @default(false)
  version           Int                    @default(1)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  taskExecutions TaskExecutionRecord[]
  participants   ServiceExecutionParticipant[]
  phasePhotos    ServiceExecutionPhoto[]

  // Enforces one shared ServiceExecution per WorkOrder at the DB level,
  // preventing duplicate creations under concurrent /start requests.
  @@unique([workOrderId])
  @@map("service_executions")
}

model ServiceExecutionPhoto {
  id                 String           @id @default(uuid()) @db.Uuid
  serviceExecution   ServiceExecution @relation(fields: [serviceExecutionId], references: [id])
  serviceExecutionId String           @db.Uuid
  phase              PhotoPhase
  storageKey         String           @db.VarChar(500)
  storageBucket      String           @db.VarChar(100) @default("local")
  originalFilename   String?          @db.VarChar(500)
  mimeType           String?          @db.VarChar(100)
  fileSizeBytes      Int?
  widthPx            Int?
  heightPx           Int?
  capturedAt         DateTime?
  uploadedAt         DateTime         @default(now())
  gpsLat             Decimal?         @db.Decimal(10, 7)
  gpsLng             Decimal?         @db.Decimal(10, 7)
  deviceId           String?          @db.VarChar(200)
  clientOperationId  String?          @unique @db.VarChar(100)
  uploadedBy         User             @relation(fields: [uploadedById], references: [id])
  uploadedById       String           @db.Uuid
  deletedAt          DateTime?
  deletedBy          String?          @db.Uuid
  createdAt          DateTime         @default(now())

  @@index([serviceExecutionId, phase, deletedAt])
  @@map("service_execution_photos")
}

// One row per worker who participates in a shared ServiceExecution.
// The ServiceExecution is created by the first user who calls /start.
// Subsequent workers call /join and get a row here.
model ServiceExecutionParticipant {
  id                 String           @id @default(uuid()) @db.Uuid
  serviceExecution   ServiceExecution @relation(fields: [serviceExecutionId], references: [id])
  serviceExecutionId String           @db.Uuid
  user               User             @relation(fields: [userId], references: [id])
  userId             String           @db.Uuid
  attendance         Attendance       @relation(fields: [attendanceId], references: [id])
  attendanceId       String           @db.Uuid
  joinedAt           DateTime
  createdAt          DateTime         @default(now())

  @@unique([serviceExecutionId, userId])
  @@map("service_execution_participants")
}

// ─── Task Executions ─────────────────────────────────────────────────────────
// CONSTRAINT: exactly one of (workOrderTaskId, periodicTaskInstanceId) must be non-null.
// workOrderTaskId → task inside a work order (snapshot)
// periodicTaskInstanceId → standalone periodic task execution

model TaskExecutionRecord {
  id                      String                @id @default(uuid()) @db.Uuid
  serviceExecution        ServiceExecution?     @relation(fields: [serviceExecutionId], references: [id])
  serviceExecutionId      String?               @db.Uuid // Non-null when workOrderTaskId is set
  workOrderTask           WorkOrderTask?        @relation(fields: [workOrderTaskId], references: [id])
  workOrderTaskId         String?               @db.Uuid
  periodicTaskInstance    PeriodicTaskInstance? @relation(fields: [periodicTaskInstanceId], references: [id])
  periodicTaskInstanceId  String?               @db.Uuid
  status                  TaskExecutionStatus
  rejectionReason         RejectionReason?      @relation(fields: [rejectionReasonId], references: [id])
  rejectionReasonId       String?               @db.Uuid // Must be type TASK_NOT_DONE
  observation             String?
  executedBy              User                  @relation(fields: [executedById], references: [id])
  executedById            String                @db.Uuid
  executedAt              DateTime
  occurredAt              DateTime? // Device timestamp (offline)
  clientOperationId       String?               @unique @db.VarChar(100)
  isOfflineSynced         Boolean               @default(false)
  version                 Int                   @default(1)

  photos      TaskPhoto[]
  fieldValues TaskExecutionFieldValue[]

  // One execution record per task per service execution — checklist is shared
  // among all participants; no two workers can mark the same task independently.
  @@unique([serviceExecutionId, workOrderTaskId])
  @@index([periodicTaskInstanceId])
  @@map("task_executions")
}

model TaskExecutionFieldValue {
  id                 String                    @id @default(uuid()) @db.Uuid
  taskExecution      TaskExecutionRecord       @relation(fields: [taskExecutionId], references: [id])
  taskExecutionId    String                    @db.Uuid
  snapshotField      WorkOrderTaskCustomField? @relation(fields: [snapshotFieldId], references: [id])
  snapshotFieldId    String?                   @db.Uuid // WO tasks — snapshot field
  masterField        TaskCustomField?          @relation(fields: [masterFieldId], references: [id])
  masterFieldId      String?                   @db.Uuid // Periodic tasks — master field
  selectedOptionIds  String[]                  @db.Uuid
  createdAt          DateTime                  @default(now())

  @@map("task_execution_field_values")
}

model TaskPhoto {
  id               String              @id @default(uuid()) @db.Uuid
  taskExecution    TaskExecutionRecord @relation(fields: [taskExecutionId], references: [id])
  taskExecutionId  String              @db.Uuid
  storageKey       String              @db.VarChar(500)
  storageBucket    String              @db.VarChar(100) @default("local")
  originalFilename String?             @db.VarChar(500)
  mimeType         String?             @db.VarChar(100)
  fileSizeBytes    Int?
  widthPx          Int?
  heightPx         Int?
  capturedAt       DateTime?
  uploadedAt       DateTime            @default(now())
  gpsLat           Decimal?            @db.Decimal(10, 7)
  gpsLng           Decimal?            @db.Decimal(10, 7)
  deviceId         String?             @db.VarChar(200)
  clientOperationId String?            @unique @db.VarChar(100)
  uploadedBy       User                @relation(fields: [uploadedById], references: [id])
  uploadedById     String              @db.Uuid
  deletedAt        DateTime?
  deletedBy        String?             @db.Uuid
  createdAt        DateTime            @default(now())

  @@map("task_photos")
}

// ─── Periodic Task Instances ──────────────────────────────────────────────────

model PeriodicTaskInstance {
  id          String                     @id @default(uuid()) @db.Uuid
  task        Task                       @relation(fields: [taskId], references: [id])
  taskId      String                     @db.Uuid
  periodLabel String                     @db.VarChar(50) // e.g. "2026-06", "2026-W23"
  periodStart DateTime                   @db.Date
  periodEnd   DateTime                   @db.Date
  status      PeriodicTaskInstanceStatus @default(PENDING)
  completedAt DateTime?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  // Executions are accessed via TaskExecutionRecord.periodicTaskInstanceId
  taskExecutions TaskExecutionRecord[]
  phasePhotos    PeriodicTaskInstancePhoto[]

  @@unique([taskId, periodLabel])
  @@map("periodic_task_instances")
}

model PeriodicTaskInstancePhoto {
  id                     String               @id @default(uuid()) @db.Uuid
  periodicTaskInstance   PeriodicTaskInstance @relation(fields: [periodicTaskInstanceId], references: [id])
  periodicTaskInstanceId String               @db.Uuid
  phase                  PhotoPhase
  storageKey             String               @db.VarChar(500)
  storageBucket          String               @db.VarChar(100) @default("local")
  originalFilename       String?              @db.VarChar(500)
  mimeType               String?              @db.VarChar(100)
  fileSizeBytes          Int?
  widthPx                Int?
  heightPx               Int?
  capturedAt             DateTime?
  uploadedAt             DateTime             @default(now())
  gpsLat                 Decimal?             @db.Decimal(10, 7)
  gpsLng                 Decimal?             @db.Decimal(10, 7)
  deviceId               String?              @db.VarChar(200)
  clientOperationId      String?              @unique @db.VarChar(100)
  uploadedBy             User                 @relation(fields: [uploadedById], references: [id])
  uploadedById           String               @db.Uuid
  deletedAt              DateTime?
  deletedBy              String?              @db.Uuid
  createdAt              DateTime             @default(now())

  @@index([periodicTaskInstanceId, phase, deletedAt])
  @@map("periodic_task_instance_photos")
}

// ─── Sync Operations ──────────────────────────────────────────────────────────
// Append-only log of every offline operation received via POST /sync/batch.
// clientOperationId is unique — guarantees idempotency across retries.

model SyncOperation {
  id                String    @id @default(uuid()) @db.Uuid
  user              User      @relation(fields: [userId], references: [id])
  userId            String    @db.Uuid
  deviceId          String    @db.VarChar(200)
  clientOperationId String    @unique @db.VarChar(200)
  operationType     String    @db.VarChar(50)  // CHECK_IN | CHECK_OUT | START_WORK_ORDER | MARK_WORK_ORDER_TASK | COMPLETE_WORK_ORDER
  entityType        String    @db.VarChar(50)
  entityId          String?   @db.Uuid
  payload           Json
  result            Json?
  status            String    @db.VarChar(20)  // SUCCESS | FAILED | ALREADY_PROCESSED | CONFLICT
  errorCode         String?   @db.VarChar(100)
  errorMessage      String?
  occurredAt        DateTime
  processedAt       DateTime?
  createdAt         DateTime  @default(now())

  @@index([userId, createdAt])
  @@map("sync_operations")
}

// ─── Sync & Conflicts ─────────────────────────────────────────────────────────

model SyncConflict {
  id                String                       @id @default(uuid()) @db.Uuid
  clientOperationId String                       @db.VarChar(100)
  deviceId          String                       @db.VarChar(200)
  user              User                         @relation("SyncConflictUser", fields: [userId], references: [id])
  userId            String                       @db.Uuid
  entityType        String                       @db.VarChar(50)
  entityId          String                       @db.Uuid
  operationType     String                       @db.VarChar(50)
  payload           Json
  occurredAt        DateTime
  receivedAt        DateTime                     @default(now())
  conflictReason    String
  resolvedBy        User?                        @relation("SyncConflictResolvedBy", fields: [resolvedById], references: [id])
  resolvedById      String?                      @db.Uuid
  resolvedAt        DateTime?
  createdAt         DateTime                     @default(now())

  @@index([userId, resolvedAt])
  @@map("sync_conflicts")
}

// ─── Integration & Audit ─────────────────────────────────────────────────────

model IntegrationInboundLog {
  id                  String               @id @default(uuid()) @db.Uuid
  source              String               @db.VarChar(100)
  headers             Json
  rawBody             String
  receivedAt          DateTime             @default(now())
  status              IntegrationLogStatus @default(RECEIVED)
  parsedPayload       Json?
  errorMessage        String?
  relatedReservation  Reservation?         @relation(fields: [relatedReservationId], references: [id])
  relatedReservationId String?             @db.Uuid
  relatedWorkOrder    WorkOrder?           @relation(fields: [relatedWorkOrderId], references: [id])
  relatedWorkOrderId  String?              @db.Uuid
  createdAt           DateTime             @default(now())

  @@index([source, status, receivedAt])
  @@map("integration_inbound_logs")
}

model DomainEvent {
  id          String    @id @default(uuid()) @db.Uuid
  eventType   String    @db.VarChar(100) // e.g. work_order.assigned
  entityType  String    @db.VarChar(50)
  entityId    String    @db.Uuid
  payload     Json
  triggeredBy User?     @relation(fields: [triggeredById], references: [id])
  triggeredById String? @db.Uuid
  occurredAt  DateTime  @default(now())
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@map("domain_events")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?  @db.Uuid
  action     String   @db.VarChar(100) // CREATE | UPDATE | DELETE | CORRECT
  entityType String   @db.VarChar(50)
  entityId   String   @db.Uuid
  oldValue   Json?
  newValue   Json?
  ip         String?  @db.VarChar(45)
  deviceId   String?  @db.VarChar(200)
  createdAt  DateTime @default(now())

  @@map("audit_log")
}

// ─── Gastos y comisiones ──────────────────────────────────────────────────────

/// Gastos opcionales asociados a un servicio eventual (concepto + monto).
model WorkOrderExpense {
  id          String    @id @default(uuid()) @db.Uuid
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  workOrderId String    @db.Uuid
  concept     String    @db.VarChar(300)
  amount      Decimal   @db.Decimal(12, 2)
  createdBy   User?     @relation("WorkOrderExpenseCreator", fields: [createdById], references: [id])
  createdById String?   @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workOrderId])
  @@map("work_order_expenses")
}

/// Gasto fijo global o por edificio, con rango de vigencia (fin opcional).
model FixedExpense {
  id          String    @id @default(uuid()) @db.Uuid
  concept     String    @db.VarChar(300)
  amount      Decimal   @db.Decimal(12, 2)
  startDate   DateTime  @db.Date
  endDate     DateTime? @db.Date
  /// null = aplica a todos los edificios (global)
  building    Building? @relation(fields: [buildingId], references: [id])
  buildingId  String?   @db.Uuid
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdBy   User?     @relation("FixedExpenseCreator", fields: [createdById], references: [id])
  createdById String?   @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  settlementLines CommissionSettlementFixedExpense[]

  @@index([deletedAt, isActive, startDate])
  @@index([buildingId])
  @@map("fixed_expenses")
}

/// Rendición / comisión generada para un beneficiario (usuario o externo).
model CommissionSettlement {
  id                   String   @id @default(uuid()) @db.Uuid
  beneficiaryUser      User?    @relation("CommissionBeneficiary", fields: [beneficiaryUserId], references: [id])
  beneficiaryUserId    String?  @db.Uuid
  /// Nombre siempre guardado (del usuario o texto libre si no es usuario).
  beneficiaryName      String   @db.VarChar(200)
  dateFrom             DateTime @db.Date
  dateTo               DateTime @db.Date
  percentage           Decimal  @db.Decimal(5, 2)
  totalClientCharged   Decimal  @db.Decimal(14, 2)
  totalServiceExpenses Decimal  @db.Decimal(14, 2)
  totalFixedExpenses   Decimal  @db.Decimal(14, 2)
  netAmount            Decimal  @db.Decimal(14, 2)
  commissionAmount     Decimal  @db.Decimal(14, 2)
  /// Desglose legible del cálculo (prorrateos, fórmulas, etc.).
  calculationBreakdown Json
  currentPdfVersion    Int      @default(1)
  createdBy            User     @relation("CommissionCreator", fields: [createdById], references: [id])
  createdById          String   @db.Uuid
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  items           CommissionSettlementItem[]
  fixedExpenses   CommissionSettlementFixedExpense[]
  pdfVersions     CommissionSettlementPdfVersion[]

  @@index([beneficiaryUserId, dateFrom, dateTo])
  @@index([createdAt])
  @@index([beneficiaryName])
  @@map("commission_settlements")
}

model CommissionSettlementItem {
  id                     String               @id @default(uuid()) @db.Uuid
  settlement             CommissionSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  settlementId           String               @db.Uuid
  workOrder              WorkOrder            @relation(fields: [workOrderId], references: [id])
  workOrderId            String               @db.Uuid
  titleSnapshot          String               @db.VarChar(300)
  scheduledDateSnapshot  DateTime?            @db.Date
  buildingNameSnapshot   String               @db.VarChar(200)
  citySnapshot           String?              @db.VarChar(100)
  provinceSnapshot       String?              @db.VarChar(100)
  clientAmountCharged    Decimal              @db.Decimal(12, 2)
  serviceExpensesTotal   Decimal              @db.Decimal(12, 2)
  /// [{ concept, amount }]
  serviceExpensesJson    Json
  /// [{ id?, fullName }]
  cleanersSnapshot       Json

  @@index([settlementId])
  @@index([workOrderId])
  @@map("commission_settlement_items")
}

model CommissionSettlementFixedExpense {
  id                   String               @id @default(uuid()) @db.Uuid
  settlement           CommissionSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  settlementId         String               @db.Uuid
  fixedExpense         FixedExpense?        @relation(fields: [fixedExpenseId], references: [id])
  fixedExpenseId       String?              @db.Uuid
  conceptSnapshot      String               @db.VarChar(300)
  buildingNameSnapshot String?              @db.VarChar(200)
  isGlobal             Boolean              @default(true)
  fullAmount           Decimal              @db.Decimal(12, 2)
  proratedAmount       Decimal              @db.Decimal(12, 2)
  daysInBasePeriod     Int
  daysOverlapping      Int
  included             Boolean              @default(true)
  prorationNote        String?

  @@index([settlementId])
  @@map("commission_settlement_fixed_expenses")
}

model CommissionSettlementPdfVersion {
  id            String               @id @default(uuid()) @db.Uuid
  settlement    CommissionSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  settlementId  String               @db.Uuid
  version       Int
  storageKey    String               @db.VarChar(500)
  storageBucket String?              @db.VarChar(100) @default("local")
  note          String?
  createdBy     User?                @relation("CommissionPdfCreator", fields: [createdById], references: [id])
  createdById   String?              @db.Uuid
  createdAt     DateTime             @default(now())

  @@unique([settlementId, version])
  @@index([settlementId])
  @@map("commission_settlement_pdf_versions")
}
