# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=steamgenie
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=steamgenie
DATABASE_URL=postgresql://steamgenie:change_me_in_production@localhost:5433/steamgenie

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=90d

# ─── API ─────────────────────────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:3000

# ─── Web Admin ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=steam-genie-dev
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── Expo / Push Notifications ───────────────────────────────────────────────
EXPO_ACCESS_TOKEN=your_expo_access_token

# ─── Seed ────────────────────────────────────────────────────────────────────
SEED_ADMIN_DNI=00000001
SEED_ADMIN_PASSWORD=Admin1234!
SEED_ADMIN_NAME=Administrador Principal
