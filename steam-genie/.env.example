# ─── Database ───────────────────────────────────────────────────────────────
# Local (Docker): usar localhost. Neon (prod/staging): ver comentarios abajo.
POSTGRES_USER=steamgenie
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=steamgenie
DATABASE_URL=postgresql://steamgenie:change_me_in_production@localhost:5433/steamgenie
# Solo Neon + Prisma migrate: conexión directa (sin pooler). En local Docker puede ser igual a DATABASE_URL.
DIRECT_URL=postgresql://steamgenie:change_me_in_production@localhost:5433/steamgenie

# Neon — runtime (host *-pooler*):
# DATABASE_URL=postgresql://USER:PASS@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Neon — migraciones / seed (host directo, sin -pooler):
# DIRECT_URL=postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=90d

# ─── API ─────────────────────────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:3000
# Railway: PORT lo asigna la plataforma (no hace falta definirlo).
# Producción: API_URL=https://<tu-servicio>.up.railway.app
# Producción: ALLOWED_ORIGINS=https://<tu-admin>.vercel.app,http://localhost:3000

# ─── Web Admin ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
# Vercel (prod): https://<tu-api>.up.railway.app
NEXT_PUBLIC_WS_URL=http://localhost:4000

# ─── Google Maps Platform (edificios) ────────────────────────────────────────
# API (servidor): Places Autocomplete + Place Details + Geocoding.
GOOGLE_MAPS_API_KEY=
# Web (navegador): Maps JavaScript API (mapa interactivo).
# Puede ser la misma key en local; en prod conviene una key con restricción HTTP referrer.
# Habilitar en Google Cloud: Places API (New), Geocoding API, Maps JavaScript API.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Cloudflare R2 (fotos de tareas) ─────────────────────────────────────────
# La API acepta S3_* o R2_* (R2_* se usa como fallback).
# Account ID: Cloudflare Dashboard → Overview (32 chars), NO el token cfat_...
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=steam-genie-dev
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Alternativa explícita (recomendada en producción):
# S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=steam-genie-dev
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_PUBLIC_BASE_URL=https://pub-xxx.r2.dev

# ─── Expo / Mobile ───────────────────────────────────────────────────────────
# API en Railway (build EAS preview/production y pruebas en dispositivo)
EXPO_PUBLIC_API_URL=https://steamgenie.up.railway.app
# Token de expo.dev para enviar push desde la API (expo-server-sdk)
EXPO_ACCESS_TOKEN=your_expo_access_token

# ─── Seed ────────────────────────────────────────────────────────────────────
SEED_ADMIN_DNI=00000001
SEED_ADMIN_PASSWORD=Admin1234!
SEED_ADMIN_NAME=Administrador Principal
