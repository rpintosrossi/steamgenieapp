{
  "name": "@steam-genie/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build:apk": "pnpm dlx eas-cli build --platform android --profile preview",
    "build:android": "pnpm dlx eas-cli build --platform android --profile production",
    "build:ios": "pnpm dlx eas-cli build --platform ios --profile production",
    "submit:ios": "pnpm dlx eas-cli submit --platform ios --profile production",
    "eas-build-post-install": "cd ../.. && pnpm --filter @steam-genie/shared-constants build && pnpm --filter @steam-genie/shared-types build && pnpm --filter @steam-genie/shared-validators build"
  },
  "dependencies": {
    "@expo/metro-runtime": "^6.1.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-community/netinfo": "^11.4.1",
    "@steam-genie/shared-constants": "workspace:*",
    "@steam-genie/shared-types": "workspace:*",
    "@steam-genie/shared-validators": "workspace:*",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "^8.0.12",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "socket.io-client": "^4.7.5",
    "whatwg-fetch": "^3.6.20",
    "zod": "^3.22.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~19.1.17",
    "typescript": "~5.9.3"
  }
}
