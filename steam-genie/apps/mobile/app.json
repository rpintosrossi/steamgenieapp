{
  "expo": {
    "name": "Steam Genie",
    "slug": "steam-genie",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "steamgenie",
    "platforms": ["ios", "android"],
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-sqlite", { "enableFTS": true }]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
