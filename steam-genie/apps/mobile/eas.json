      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://steamgenie.up.railway.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
